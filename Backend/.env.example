# Existing monolith config
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>/<database>?retryWrites=true&w=majority
SECRET_KEY=replace_with_secure_secret
CLIENT_ID=your_google_client_id
CLIENT_SECRET=your_google_client_secret
REFRESH_TOKEN=your_google_refresh_token
EMAIL_USER=your_email@gmail.com
EMAIL_PASSWORD=your_email_app_password

# Phase 1 migration runtime config
# Public entrypoint for frontend and external clients
PORT=3001
GATEWAY_PORT=3001

# Internal legacy service port (frontend must not call this directly)
LEGACY_SERVICE_PORT=3002

# Optional explicit URL for legacy service (overrides LEGACY_SERVICE_PORT)
# LEGACY_SERVICE_URL=http://127.0.0.1:3002

# API Gateway timeout (ms)
GATEWAY_PROXY_TIMEOUT_MS=15000
